// find a song
{
  "resource": "/api/{proxy+}",
  "path": "/api/music",
  "httpMethod": "GET",
  "headers": {
    "Content-Type": "application/json"
  },
  "queryStringParameters": {
    "artist": "Taylor",
    "year": "2017"
  },
  "pathParameters": {
    "proxy": "music"
  },
  "body": null,
  "isBase64Encoded": false
},
// login a valid user
{
  "resource": "/api/{proxy+}",
  "path": "/api/login",
  "httpMethod": "POST",
  "headers": {
    "Content-Type": "application/json"
  },
  "queryStringParameters": null,
  "pathParameters": {
    "proxy": "login"
  },
  "body": "{\"email\": \"testuser@example.com\", \"password\": \"Abc@123456\"}",
  "isBase64Encoded": false
},
// login a user that does not exist
{
  "resource": "/api/{proxy+}",
  "path": "/api/login",
  "httpMethod": "POST",
  "headers": {
    "Content-Type": "application/json"
  },
  "queryStringParameters": null,
  "pathParameters": {
    "proxy": "login"
  },
  "body": "{\"email\": \"testuserdoesnotexist@example.com\", \"password\": \"Abc@123456\"}",
  "isBase64Encoded": false
},
