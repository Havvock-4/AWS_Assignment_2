// remove subscription of a song
{
  "resource": "/api/{proxy+}",
  "path": "/api/subscriptions",
  "httpMethod": "DELETE",
  "headers": {
    "Content-Type": "application/json"
  },
  "queryStringParameters": null,
  "pathParameters": {
    "proxy": "subscriptions"
  },
  "body": "{\"email\": \"testuser@example.com\", \"id\": \"d00928f3-5035-43d4-85c2-782c2616e422\"}",
  "isBase64Encoded": false
},
